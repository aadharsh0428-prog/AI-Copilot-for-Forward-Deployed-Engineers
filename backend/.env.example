# Dataleap Workshop Copilot — Environment Configuration
# Copy this to .env and fill in your values

# ==============================================
# LLM Configuration
# ==============================================

# Ollama (FREE - recommended, runs locally)
# Install: https://ollama.ai
# Pull model: ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI (optional fallback - very cheap with gpt-4o-mini)
# Get key: https://platform.openai.com
# OPENAI_API_KEY=sk-...

# ==============================================
# Whisper Transcription
# ==============================================
# Option 1: OpenAI Whisper API (set OPENAI_API_KEY above)
#   - $0.006/minute, very cheap
#   - Best accuracy for German
#
# Option 2: Local Whisper CLI
#   - pip install openai-whisper
#   - Requires ffmpeg: apt install ffmpeg
#   - Runs fully offline
#   - Slower but free
#
# Option 3: Stub mode (no API key needed)
#   - Returns sample German text for development

# ==============================================
# App Configuration
# ==============================================
ENVIRONMENT=development
LOG_LEVEL=INFO
